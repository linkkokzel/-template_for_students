<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Расходы за неделю" Height="450" Width="400">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Пн:" Margin="5"/>
        <TextBox x:Name="tbMon" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="1" Text="Вт:" Margin="5"/>
        <TextBox x:Name="tbTue" Grid.Row="1" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="2" Text="Ср:" Margin="5"/>
        <TextBox x:Name="tbWed" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="3" Text="Чт:" Margin="5"/>
        <TextBox x:Name="tbThu" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="4" Text="Пт:" Margin="5"/>
        <TextBox x:Name="tbFri" Grid.Row="4" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="5" Text="Сб:" Margin="5"/>
        <TextBox x:Name="tbSat" Grid.Row="5" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="6" Text="Вс:" Margin="5"/>
        <TextBox x:Name="tbSun" Grid.Row="6" Grid.Column="1" Margin="5"/>

        <Button Grid.Row="7" Grid.Column="0"
                Content="Посчитать"
                Margin="5"
                Click="ButtonCalculate_Click"/>

        <Button Grid.Row="7" Grid.Column="1"
                Content="Очистить всё"
                Margin="5"
                Click="ButtonClear_Click"/>

        <TextBlock x:Name="txtResult"
                   Grid.Row="8"
                   Grid.ColumnSpan="2"
                   Margin="5"
                   TextWrapping="Wrap"
                   Background="LightGreen"/>
    </Grid>
</Window>