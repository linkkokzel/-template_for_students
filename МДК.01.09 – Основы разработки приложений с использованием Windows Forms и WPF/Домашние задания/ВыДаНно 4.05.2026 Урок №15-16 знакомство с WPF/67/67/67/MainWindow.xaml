<Window x:Class="_67.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кредит" Height="350" Width="400">

    <StackPanel Margin="10">

        <TextBlock Text="Сумма кредита"/>

        <TextBox x:Name="tbSum"
                 Margin="0,5,0,10"/>

        <TextBlock Text="Процентная ставка (%)"/>

        <TextBox x:Name="tbPercent"
                 Margin="0,5,0,10"/>

        <TextBlock Text="Срок (лет)"/>

        <TextBox x:Name="tbYears"
                 Margin="0,5,0,10"/>

        <Button Content="Рассчитать"
                Height="30"
                Click="Button_Click"/>

        <TextBlock x:Name="tbResult"
                   Margin="0,15,0,0"
                   FontSize="16"
                   TextWrapping="Wrap"/>

    </StackPanel>

</Window>