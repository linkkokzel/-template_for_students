<Window x:Class="pipun.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Площадь фигур" Height="350" Width="400">

    <StackPanel Margin="10">

        <TextBlock Text="Выберите фигуру"/>

        <ComboBox x:Name="cbFigure" Margin="0,5,0,10">
            <ComboBoxItem Content="Квадрат"/>
            <ComboBoxItem Content="Прямоугольник"/>
            <ComboBoxItem Content="Круг"/>
        </ComboBox>

        <TextBlock Text="Первое значение"/>

        <TextBox x:Name="tb1" Margin="0,5,0,10"/>

        <TextBlock Text="Второе значение"/>

        <TextBox x:Name="tb2" Margin="0,5,0,10"/>

        <Button Content="Рассчитать"
                Height="30"
                Click="Button_Click"/>

        <TextBlock x:Name="txtResult"
                   Margin="0,20,0,0"
                   FontSize="16"/>

    </StackPanel>

</Window>